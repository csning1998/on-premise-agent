
# Agent Stuffs
.agents
artifacts

# Environment variables
.env
.env.*
!.env.example

# Backup Files
**/*.bak

# Pipelines Runtime Artifacts
pipelines/workflows/**/valves.json

# Python caches and virtual environments
**/__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.ruff_cache/
.venv/
venv/

# Node/TypeScript (OpenClaw plugins)
openclaw/plugins/*/node_modules/
openclaw/plugins/*/dist/

# Terraform
.terraform/
.terraform.tfstate.lock.info
terraform.tfstate
terraform.tfstate.*
terraform.tfstate.backup
terraform/*.tf.bak
terraform.tfvars
*.auto.tfvars

# GitLab
# 1. GitLab HTTP Backend credentials
terraform/backend-auth.hcl
terraform/backend-state.json

# 2. GitLab Runner for this Repository
runner-config/

# Data Directories
ollama_data/
open-webui_data/
openclaw_data/

# OpenClaw gateway runtime state and config (config directory is a whole-dir
# bind mount; the gateway rewrites openclaw.json at runtime, so only the
# template is tracked, matching the .env/.env.example pattern)
openclaw/config/*
!openclaw/config/openclaw.json.example

# HashiCorp Vault (Podman bootstrapper)
vault/data/
vault/tls/
vault/keys/

# Logs
*.log

# Only for recording by commit messages personally.
merge-request.md
temp-SPEC.md
