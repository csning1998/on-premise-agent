
# GitLab Runner for this Repository
# 1. Absolute path to the user home directory. Obtain with: echo $HOME
UHOME=

# 2. Numeric UID of the host user. Required to resolve the rootless Podman socket
#    at /run/user/<HOST_UID>/podman/podman.sock.
#    Obtain with: id -u
HOST_UID=

# Container Image Versions
# 1. Ollama: https://hub.docker.com/r/ollama/ollama/tags
OLLAMA_VERSION=0.30.11

# 2. Open WebUI Frontend: https://github.com/open-webui/open-webui/pkgs/container/open-webui
OPEN_WEBUI_VERSION=git-08f64f7@sha256:d595b86d24868a605a69ad84ed73cb7896c1791e9d3785ddb52d91903e07d5c1

# 3. Open WebUI Pipeline: https://github.com/open-webui/open-webui/pkgs/container/pipelines
PIPELINES_VERSION=git-039f9c5-cuda@sha256:fc4a76abf65e464f51c9e0969ca3856e9fac48b35944d15f80b82b0f62f19108

# 4. SearXNG: https://hub.docker.com/r/searxng/searxng/tags
SEARXNG_VERSION=2026.6.26-f8ffbf36f


# Ollama Service (docker.io/ollama/ollama)
## (Ollama service uses no variable envs in compose.yaml)

# Open WebUI Service (ghcr.io/open-webui/open-webui)
WEBUI_SECRET_KEY="your_webui_secret_key"

# 1. Admin Credentials
WEBUI_ADMIN_EMAIL="your_admin_email"
WEBUI_ADMIN_PASSWORD="your_admin_password"
WEBUI_ADMIN_NAME=Admin
ENABLE_SIGNUP=True

# 2. OpenAI / Ollama Connection
ENABLE_OPENAI_API="True"
OLLAMA_BASE_URL="http://ollama:11434"

# 3. RAG Configuration
ENABLE_RAG_WEB_SEARCH=True
ENABLE_RAG_WEB_SEARCH_BY_DEFAULT=True
RAG_WEB_SEARCH_ENGINE=searxng
SEARXNG_BASE_URL=http://searxng:8080
SEARXNG_QUERY_URL=http://searxng:8080/search?q=<query>&engines=google

# 4. Web Search Settings
ENABLE_WEB_SEARCH=True
ENABLE_WEB_SEARCH_BY_DEFAULT=True
WEB_SEARCH_ENGINE=searxng
WEB_SEARCH_QUERY_URL=http://searxng:8080/search?q=<query>&engines=google
WEB_SEARCH_CONCURRENT_REQUESTS="5"
WEB_SEARCH_RESULT_COUNT="20"

# 5. RAG Precision Tuning & Reranking
ENABLE_RAG_RERANKING=True
ENABLE_RAG_SOURCES=True
RAG_CITATION_ENGINE=True
RAG_RELEVANCE_THRESHOLD=0.5
RAG_RERANKING_MODEL=BAAI/bge-reranker-v2-m3
RAG_TOP_K=15
RAG_TOP_K_RERANKER=8

# 6. Pipelines Integration
OPENAI_API_BASE_URLS="http://pipelines:9099/v1"
OPENAI_API_KEYS="<generate-a-strong-key>"

# 7. Infrastructure & UI Control
ENABLE_PERSISTENT_CONFIG=False
WEBUI_SYSTEM_PROMPT=""


# SearXNG Service (docker.io/searxng/searxng)
SEARXNG_SECRET="<generate-a-strong-key>"

# Pipelines Service (ghcr.io/open-webui/pipelines)
## (Pipelines service references variables OLLAMA_BASE_URL, SEARXNG_BASE_URL, and OPENAI_API_KEYS)
BRAVE_API_KEY="<get-from-https://api.search.brave.com/>"


# Future / Unbound Configurations (Pending for future implementation)
CLOUDFLARE_API_TOKEN="your_cloudflare_api_token"
CLOUDFLARE_ZONE_ID="your_cloudflare_zone_id"
CLOUDFLARE_DOMAIN_NAME="your_cloudflare_domain_name"
DB_PASSWORD="<replace-with-strong-password>"
